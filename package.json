{
  "name": "art-of-motion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "tsx scripts/split-locales.ts",
    "predev": "tsx scripts/split-locales.ts",
    "dev": "next dev",
    "prebuild": "tsx scripts/split-locales.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "tscheck": "tsc --noEmit",
    "check": "npm run tscheck && npm run lint",
    "format": "prettier --write .",
    "locales:split": "tsx scripts/split-locales.ts",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "types:generate": "supabase gen types typescript --project-id ofasewgyeurvywflhctd --schema public > src/types/database.types.ts && prettier --write src/types/database.types.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@hookform/resolvers": "5.4.0",
    "@next/third-parties": "16.2.11",
    "@radix-ui/react-avatar": "1.2.3",
    "@radix-ui/react-dropdown-menu": "2.1.21",
    "@radix-ui/react-label": "2.1.12",
    "@radix-ui/react-slot": "1.3.0",
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.8",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "embla-carousel-react": "8.6.0",
    "lucide-react": "1.25.0",
    "next": "16.2.11",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.82.0",
    "server-only": "0.0.1",
    "shadcn": "4.13.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
